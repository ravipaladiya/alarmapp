<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Lumen" parent="android:Theme.Material.NoTitleBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">@color/bg_app</item>
    </style>

    <style name="Theme.Lumen.Fullscreen" parent="Theme.Lumen">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowShowWhenLocked">true</item>
        <item name="android:windowTurnScreenOn">true</item>
        <item name="android:windowDismissKeyguard">true</item>
    </style>
</resources>
